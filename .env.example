# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=<secret>
POSTGRES_DB=3dp_manager

# JWT
JWT_SECRET=<secret>

# Admin credentials
ADMIN_LOGIN=admin
ADMIN_PASSWORD=<secret>

# Server
PORT=3100
LOG_LEVEL=error

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost
